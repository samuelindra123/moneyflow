# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ============================================
# DATABASE — INSFORGE POSTGRESQL
# ============================================
# Format: postgresql://user:password@host:port/dbname?sslmode=require
# Dapatkan dari: Insforge Dashboard → Database → Connection String
DATABASE_URL="postgresql://username:password@host.insforge.app:5432/dbname?sslmode=require&connection_limit=5&pool_timeout=0"

# ============================================
# GOOGLE OAUTH
# ============================================
# Dapatkan dari: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# ============================================
# JWT
# ============================================
# Gunakan string random panjang (min 32 karakter)
JWT_ACCESS_SECRET="your_super_secret_jwt_access_key_minimum_32_chars"
JWT_REFRESH_SECRET="your_super_secret_jwt_refresh_key_minimum_32_chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# INSFORGE STORAGE (S3-COMPATIBLE)
# ============================================
# Dapatkan dari: Insforge Dashboard → Storage → Settings → S3 Configuration
# PENTING: Secret Key hanya tampil sekali saat pembuatan!
INSFORGE_S3_ENDPOINT="https://project-ref.region.insforge.app/storage/v1/s3"
INSFORGE_S3_REGION="us-east-2"
INSFORGE_S3_ACCESS_KEY_ID="your_insforge_s3_access_key_id"
INSFORGE_S3_SECRET_ACCESS_KEY="your_insforge_s3_secret_access_key"
INSFORGE_S3_BUCKET_AVATARS="avatars"
# URL publik untuk mengakses file yang sudah diupload
INSFORGE_PUBLIC_STORAGE_URL="https://project-ref.region.insforge.app/storage/v1/object/public"

# ============================================
# THROTTLER (RATE LIMITING)
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ============================================
# CORS
# ============================================
# Pisahkan dengan koma jika lebih dari satu
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
